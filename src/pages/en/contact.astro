---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar';
import Footer from '../../components/Footer';
import FadeIn from '../../components/FadeIn';
import { ui } from '../../i18n/ui';
---

<Layout title="Contact Us | Vibal Tours">
	<Navbar lang="en" client:load />
	<main class="pt-32 pb-24 min-h-[70vh] relative">
		<!-- Decorative background blob -->
		<div class="absolute top-0 inset-x-0 h-64 bg-slate-50 border-b border-slate-200/50 -z-10"></div>
		
		<FadeIn client:load className="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center max-w-2xl mx-auto mb-16">
				<h1 class="text-4xl md:text-5xl font-display font-bold text-slate-900 mb-4">Contact Us</h1>
				<p class="text-xl text-slate-600">
					Do you have any questions or want to book a tour? Write to us and we will reply as soon as possible.
				</p>
			</div>

			<div class="grid grid-cols-1 lg:grid-cols-5 gap-8 lg:gap-12">
				
				<!-- Left Column: Form -->
				<div class="lg:col-span-3 bg-white p-8 md:p-10 rounded-3xl shadow-xl shadow-slate-200/40 border border-slate-100 relative overflow-hidden">
					<!-- Form accent line -->
					<div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-brand-400 to-brand-600"></div>
					
					<h3 class="text-2xl font-bold text-slate-900 mb-8">Send us a message</h3>
					<form class="flex flex-col gap-6">
						<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
							<div class="relative">
								<label for="name" class="block text-sm font-semibold text-slate-700 mb-2">Full Name</label>
								<div class="relative group">
									<input type="text" id="name" class="w-full pl-12 pr-4 py-3.5 rounded-xl border border-slate-200 bg-slate-50 focus:bg-white focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500 outline-none transition-all" placeholder="John Doe" />
									<svg class="w-5 h-5 text-slate-400 absolute left-4 top-1/2 -translate-y-1/2 group-focus-within:text-brand-500 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
								</div>
							</div>
							<div class="relative">
								<label for="email" class="block text-sm font-semibold text-slate-700 mb-2">Email Address</label>
								<div class="relative group">
									<input type="email" id="email" class="w-full pl-12 pr-4 py-3.5 rounded-xl border border-slate-200 bg-slate-50 focus:bg-white focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500 outline-none transition-all" placeholder="john@example.com" />
									<svg class="w-5 h-5 text-slate-400 absolute left-4 top-1/2 -translate-y-1/2 group-focus-within:text-brand-500 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
								</div>
							</div>
						</div>
						<div class="relative">
							<label for="message" class="block text-sm font-semibold text-slate-700 mb-2">Message</label>
							<div class="relative group">
								<textarea id="message" rows="5" class="w-full pl-12 pr-4 py-3.5 rounded-xl border border-slate-200 bg-slate-50 focus:bg-white focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500 outline-none transition-all resize-none" placeholder="How can we help you?"></textarea>
								<svg class="w-5 h-5 text-slate-400 absolute left-4 top-4 group-focus-within:text-brand-500 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" /></svg>
							</div>
						</div>
						<button type="button" class="w-full bg-brand-600 hover:bg-brand-500 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-brand-500/30 text-white font-bold py-4 px-6 rounded-xl transition-all duration-300 mt-2">
							Send Message
						</button>
					</form>
				</div>
				
				<!-- Right Column: Contact Info Panel -->
				<div class="lg:col-span-2 bg-slate-900 text-white p-8 md:p-10 rounded-3xl shadow-2xl relative overflow-hidden flex flex-col justify-between">
					<!-- Decorational background circles -->
					<div class="absolute -bottom-32 -right-32 w-80 h-80 bg-brand-500/20 rounded-full blur-3xl pointer-events-none"></div>
					<div class="absolute -top-32 -left-32 w-80 h-80 bg-brand-400/20 rounded-full blur-3xl pointer-events-none"></div>

					<div class="relative z-10">
						<h3 class="text-2xl font-bold mb-8 text-white">Contact Information</h3>
						<ul class="flex flex-col gap-8">
							<li class="flex items-start gap-4 group">
								<div class="w-12 h-12 bg-white/5 rounded-xl flex items-center justify-center shrink-0 border border-white/10 group-hover:bg-brand-500/20 group-hover:border-brand-500/30 transition-colors">
									<svg class="w-6 h-6 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
								</div>
								<div class="flex flex-col gap-1.5 mt-0.5">
									<span class="text-slate-400 text-xs font-bold uppercase tracking-widest">Main Office</span>
									<span class="font-medium text-slate-100 leading-snug">Jr. 2 de Mayo #569 Int. 1, Cajamarca</span>
								</div>
							</li>
							<li class="flex items-start gap-4 group">
								<div class="w-12 h-12 bg-white/5 rounded-xl flex items-center justify-center shrink-0 border border-white/10 group-hover:bg-brand-500/20 group-hover:border-brand-500/30 transition-colors">
									<svg class="w-6 h-6 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
								</div>
								<div class="flex flex-col gap-1.5 mt-0.5">
									<span class="text-slate-400 text-xs font-bold uppercase tracking-widest">Branch</span>
									<span class="font-medium text-slate-100 leading-snug">Av. Antonio Raymondi #216, San Pedro de Lloc, La Libertad</span>
								</div>
							</li>
							<li class="flex items-start gap-4 group">
								<div class="w-12 h-12 bg-white/5 rounded-xl flex items-center justify-center shrink-0 border border-white/10 group-hover:bg-brand-500/20 group-hover:border-brand-500/30 transition-colors">
									<svg class="w-6 h-6 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
								</div>
								<div class="flex flex-col gap-1.5 mt-1.5">
									<a href="tel:+51958139576" class="font-medium text-slate-100 hover:text-brand-400 transition-colors">+51 958 139 576</a>
									<a href="tel:+51949795898" class="font-medium text-slate-100 hover:text-brand-400 transition-colors">+51 949 795 898</a>
								</div>
							</li>
							<li class="flex items-start gap-4 group">
								<div class="w-12 h-12 bg-white/5 rounded-xl flex items-center justify-center shrink-0 border border-white/10 group-hover:bg-brand-500/20 group-hover:border-brand-500/30 transition-colors">
									<svg class="w-6 h-6 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
								</div>
								<div class="flex flex-col mt-3">
									<a href="mailto:reservas@vibaltours.com" class="font-medium text-slate-100 hover:text-brand-400 transition-colors break-all">reservas@vibaltours.com</a>
								</div>
							</li>
						</ul>
					</div>

					<div class="relative z-10 mt-12 pt-8 border-t border-white/10">
						<a href="https://wa.me/51958139576" target="_blank" rel="noopener noreferrer" class="flex items-center justify-center gap-3 w-full bg-[#25D366] hover:bg-[#20bd5a] text-white font-bold py-4 px-6 rounded-xl transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-[#25D366]/30">
							<svg class="w-6 h-6 fill-current" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
							Chat on WhatsApp
						</a>
					</div>
				</div>
			</div>
		</FadeIn>
	</main>
	<Footer lang="en" />
</Layout>
