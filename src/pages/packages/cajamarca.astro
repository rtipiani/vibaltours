---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar';
import Footer from '../../components/Footer';
import Itinerary from '../../components/Itinerary';
import { MapPin } from 'lucide-react';

const itinerary = [
  {
    day: 1,
    title: "City Tour Histórico",
    description: "Recepción y traslado al hotel. Visita a la Plaza de Armas, Cuarto de Rescate del Inca Atahualpa, Iglesia de San Francisco y el mirador de Santa Apolonia para una vista panorámica de la ciudad."
  },
  {
    day: 2,
    title: "Ruta del Valle y Baños del Inca",
    description: "Visita a las Ventanillas de Otuzco (necrópolis preinca). Por la tarde, relajación en las históricas aguas termales de los Baños del Inca."
  },
  {
    day: 3,
    title: "Hacienda La Collpa y Despedida",
    description: "Visita a la famosa hacienda donde 'llaman a las vacas por su nombre', degustación de quesos y manjar blanco. A la hora indicada, traslado al aeropuerto o terrapuerto."
  }
];
---

<Layout title="Cajamarca: Historia y Tradición | Vibal Tours">
	<Navbar lang="es" isTransparent={true} client:load />
	
	<!-- Hero Section -->
	<div class="relative h-[60vh] min-h-[500px] flex items-center justify-center overflow-hidden">
		<div class="absolute inset-0 bg-gradient-to-b from-slate-900/60 via-slate-900/40 to-slate-900/80 z-10"></div>
		<img 
			src="https://images.unsplash.com/photo-1587595431973-160d0d94add1?q=80&w=2000&auto=format&fit=crop" 
			alt="Cajamarca" 
			class="absolute inset-0 w-full h-full object-cover object-center z-0"
		/>
		
		<div class="relative z-20 text-center px-4 max-w-5xl mx-auto pt-20">
			<span class="inline-block py-1 px-3 rounded-full bg-accent-500/20 text-accent-300 backdrop-blur-sm border border-accent-500/30 text-sm font-semibold tracking-wide mb-6">
				🌿 Paquetes Exclusivos
			</span>
			<h1 class="text-3xl md:text-5xl lg:text-6xl font-display font-bold text-white mb-6 leading-tight">
				CAJAMARCA <br/><span class="text-2xl md:text-4xl font-light text-slate-200">HISTORIA Y TRADICIÓN</span>
			</h1>
			<div class="flex flex-wrap items-center justify-center gap-4 sm:gap-8 text-white font-medium">
				<div class="flex items-center gap-2">
					<MapPin className="w-5 h-5 text-accent-400" />
					<span>Cajamarca, Perú</span>
				</div>
			</div>
		</div>
	</div>

	<main class="pt-24 pb-12 bg-slate-50">
		<Itinerary days={itinerary} lang="es" client:load />
	</main>
	<Footer lang="es" />
</Layout>
