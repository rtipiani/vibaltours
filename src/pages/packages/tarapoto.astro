---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar';
import Footer from '../../components/Footer';
import Itinerary from '../../components/Itinerary';
import { Calendar, MapPin, Clock } from 'lucide-react';

const itinerary = [
  {
    day: 1,
    title: "Llegada y Aclimatación",
    description: "Recepción en el aeropuerto y traslado al hotel. Tarde libre para disfrutar de las instalaciones o dar un paseo por la ciudad de las palmeras."
  },
  {
    day: 2,
    title: "Laguna Azul (Sauce)",
    description: "Excursión de día completo cruzando el río Huallaga. Disfrutaremos de un relajante paseo en bote por la laguna, tiempo para bañarse y un delicioso almuerzo turístico."
  },
  {
    day: 3,
    title: "Cataratas de Ahuashiyacu",
    description: "Caminata rodeada de flora y fauna tropical hasta llegar a la imponente caída de agua de 40 metros. Podrás darte un baño refrescante. Tarde para relax."
  },
  {
    day: 4,
    title: "Ciudad de Lamas",
    description: "Visita a la 'Ciudad de los tres pisos naturales', conociendo su hermosa plaza de armas, el icónico Castillo de Lamas y la comunidad nativa Wayku."
  },
  {
    day: 5,
    title: "Despedida",
    description: "Mañana libre para realizar compras de artesanías y probar los deliciosos chocolates locales. A la hora oportuna, traslado al aeropuerto."
  }
];
---

<Layout title="Tarapoto: Ciudad de las Palmeras | Vibal Tours">
	<Navbar lang="es" isTransparent={true} client:load />
	
	<!-- Hero Section -->
	<div class="relative h-[60vh] min-h-[500px] flex items-center justify-center overflow-hidden">
		<div class="absolute inset-0 bg-gradient-to-b from-slate-900/60 via-slate-900/40 to-slate-900/80 z-10"></div>
		<img 
			src="https://images.unsplash.com/photo-1596422846543-75c6fc197f07?q=80&w=2000&auto=format&fit=crop" 
			alt="Tarapoto" 
			class="absolute inset-0 w-full h-full object-cover object-center z-0"
		/>
		
		<div class="relative z-20 text-center px-4 max-w-5xl mx-auto pt-20">
			<span class="inline-block py-1 px-3 rounded-full bg-accent-500/20 text-accent-300 backdrop-blur-sm border border-accent-500/30 text-sm font-semibold tracking-wide mb-6">
				🌿 Paquetes Exclusivos
			</span>
			<h1 class="text-3xl md:text-5xl lg:text-6xl font-display font-bold text-white mb-6 leading-tight">
				TARAPOTO <br/><span class="text-2xl md:text-4xl font-light text-slate-200">CIUDAD DE LAS PALMERAS</span>
			</h1>
			<div class="flex flex-wrap items-center justify-center gap-4 sm:gap-8 text-white font-medium">
				<div class="flex items-center gap-2">
					<MapPin className="w-5 h-5 text-accent-400" />
					<span>Tarapoto, Perú</span>
				</div>
			</div>
		</div>
	</div>

	<main class="pt-24 pb-12 bg-slate-50">
		<Itinerary days={itinerary} lang="es" client:load />
	</main>
	<Footer lang="es" />
</Layout>
