---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar';
import Footer from '../../components/Footer';
---

<Layout title="Viajes para grupos organizados | Vibal Tours">
	<Navbar lang="es" isTransparent={true} client:load />
	
	<!-- Hero Section -->
	<div class="relative h-[60vh] min-h-[500px] flex items-center justify-center overflow-hidden">
		<div class="absolute inset-0 bg-gradient-to-b from-slate-900/60 via-slate-900/40 to-slate-900/80 z-10"></div>
		<img 
			src="https://images.unsplash.com/photo-1517486808906-6ca8b3f04846?q=80&w=2000&auto=format&fit=crop" 
			alt="Viajes para grupos" 
			class="absolute inset-0 w-full h-full object-cover object-center z-0"
		/>
		
		<div class="relative z-20 text-center px-4 max-w-5xl mx-auto pt-20">
			<span class="inline-block py-1 px-3 rounded-full bg-accent-500/20 text-accent-300 backdrop-blur-sm border border-accent-500/30 text-sm font-semibold tracking-wide mb-6">
				🌿 Vibal Tours
			</span>
			<h1 class="text-3xl md:text-5xl lg:text-6xl font-display font-bold text-white mb-6 leading-tight">
				VIAJES PARA <br/><span class="text-2xl md:text-4xl font-light text-slate-200">GRUPOS ORGANIZADOS</span>
			</h1>
		</div>
	</div>

	<main class="py-24 bg-slate-50 text-center">
		<div class="max-w-3xl mx-auto px-4">
			<h2 class="text-3xl font-display font-bold text-slate-900 mb-6">Experiencias inolvidables en grupo</h2>
			<p class="text-lg text-slate-600 mb-8">
				Pronto tendremos más información sobre nuestros viajes grupales. Por ahora, no dudes en contactarnos para coordinar tu viaje.
			</p>
			<a href="/contact" class="inline-block bg-brand-600 text-white font-bold py-3 px-8 rounded-xl hover:bg-brand-700 transition-colors">
				Contáctanos
			</a>
		</div>
	</main>
	<Footer lang="es" />
</Layout>
