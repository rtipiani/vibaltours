---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar';
import Footer from '../../components/Footer';
import Itinerary from '../../components/Itinerary';
import { MapPin } from 'lucide-react';

const itinerary = [
  {
    day: 1,
    title: "Viaje y Cataratas",
    description: "Llegada a la selva central. Visita a las hermosas cataratas locales, caminata por senderos naturales y tiempo para disfrutar del paisaje y la flora exótica de la zona."
  },
  {
    day: 2,
    title: "Colonia Austro-Alemana y Retorno",
    description: "Recorrido por la ciudad de Oxapampa, conociendo su particular arquitectura de madera. Visita a plantas lecheras, degustación de productos típicos y por la tarde, viaje de retorno."
  }
];
---

<Layout title="Aventura en Oxapampa | Vibal Tours">
	<Navbar lang="es" isTransparent={true} client:load />
	
	<!-- Hero Section -->
	<div class="relative h-[60vh] min-h-[500px] flex items-center justify-center overflow-hidden">
		<div class="absolute inset-0 bg-gradient-to-b from-slate-900/60 via-slate-900/40 to-slate-900/80 z-10"></div>
		<img 
			src="https://images.unsplash.com/photo-1547481183-7c30f46d9d06?auto=format&fit=crop&w=2000&q=80" 
			alt="Oxapampa" 
			class="absolute inset-0 w-full h-full object-cover object-center z-0"
		/>
		
		<div class="relative z-20 text-center px-4 max-w-5xl mx-auto pt-20">
			<span class="inline-block py-1 px-3 rounded-full bg-accent-500/20 text-accent-300 backdrop-blur-sm border border-accent-500/30 text-sm font-semibold tracking-wide mb-6">
				🌿 Tour Aventura
			</span>
			<h1 class="text-3xl md:text-5xl lg:text-6xl font-display font-bold text-white mb-6 leading-tight">
				AVENTURA EN <br/><span class="text-2xl md:text-4xl font-light text-slate-200">OXAPAMPA</span>
			</h1>
			<div class="flex flex-wrap items-center justify-center gap-4 sm:gap-8 text-white font-medium">
				<div class="flex items-center gap-2">
					<MapPin className="w-5 h-5 text-accent-400" />
					<span>Oxapampa, Perú</span>
				</div>
			</div>
		</div>
	</div>

	<main class="pt-24 pb-12 bg-slate-50">
		<Itinerary days={itinerary} lang="es" client:load />
	</main>
	<Footer lang="es" />
</Layout>
